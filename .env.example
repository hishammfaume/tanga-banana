# PostgreSQL connection string used by Payload
DATABASE_URL=postgresql://127.0.0.1:5432/tanga_banana

# Payload auth / encryption secret
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Public site URL used for SEO metadata, CORS, and sitemap generation. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# SMTP settings used for contact and booking emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=replace-with-your-smtp-password

# Internal notification recipients
BOOKING_NOTIFICATION_EMAIL=bookings@example.com
CONTACT_NOTIFICATION_EMAIL=hello@example.com

# Optional fallback recipient if the more specific notification emails are not set
SMTP_TO=admin@example.com

# Secret used to authenticate cron jobs
CRON_SECRET=replace-with-a-random-cron-secret

# Secret used to validate preview requests
PREVIEW_SECRET=replace-with-a-random-preview-secret
